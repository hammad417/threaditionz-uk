# Threaditionz storefront — environment variables.
# Copy to .env.local for local dev; add the same keys in Vercel
# (Project → Settings → Environment Variables) for Production + Preview.

# --- Shopify (required) ---
SHOPIFY_STORE_DOMAIN="[your-store].myshopify.com"
SHOPIFY_STOREFRONT_ACCESS_TOKEN=""   # read: products, cart, checkout, customers
SHOPIFY_ADMIN_ACCESS_TOKEN=""        # writes: media, shipping rules (server-only)
SHOPIFY_REVALIDATION_SECRET=""       # secures the cache webhook (see below)

# --- Site (required) ---
COMPANY_NAME="Threaditionz"
SITE_NAME="Threaditionz"
# Canonical production origin — drives canonical, sitemap, OG, JSON-LD.
# MUST be the final custom domain.
NEXT_PUBLIC_SITE_URL="https://threaditionz.co.uk"

# --- Commerce (optional) ---
# Cart free-shipping bar; MUST match a real Shopify free-shipping rule.
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD="50"

# --- Analytics (optional — each tag loads only when its ID is set; consent-gated) ---
NEXT_PUBLIC_GA_ID=""            # GA4, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_FB_PIXEL_ID=""      # Meta Pixel ID
NEXT_PUBLIC_CLARITY_ID=""       # Microsoft Clarity project ID

# Shopify cache-revalidation webhook (configure in Shopify admin → Notifications → Webhooks):
#   POST https://<your-domain>/api/revalidate?secret=<SHOPIFY_REVALIDATION_SECRET>
#   Topics: products/create|update|delete, collections/create|update|delete
