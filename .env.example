NEXT_PUBLIC_FB_PIXEL_ID=""      # Meta Pixel ID
NEXT_PUBLIC_CLARITY_ID=""      # Microsoft Clarity project ID

# Cart free-shipping progress bar — store currency value; MUST match a real Shopify free-shipping rule
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=""
